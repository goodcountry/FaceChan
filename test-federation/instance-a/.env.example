# Instance A — federation test
# Copy this file: cp .env.example .env
# Then fill in the values below.

# ── Required ────────────────────────────────────────────────────────────────

SECRET_KEY=replace-with-a-long-random-string-instance-a
POSTGRES_PASSWORD=replace-with-a-strong-password-a

# ── Database (defaults match docker-compose.yml — change only if needed) ───

POSTGRES_DB=facechan_a
POSTGRES_USER=facechan_a

# ── Hosts ───────────────────────────────────────────────────────────────────

# Set this AFTER first boot once you have your .onion address.
# Get it with:
#   docker compose -f test-federation/instance-a/docker-compose.yml -p fc-a logs tor
#
# Format: http://<your-onion-address>.onion
FEDERATION_BASE_URL=

# ALLOWED_HOSTS must include your onion address (without http://)
# e.g. ALLOWED_HOSTS=abc123.onion
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Optional ────────────────────────────────────────────────────────────────

# CORS_ALLOWED_ORIGINS=http://localhost:8101
