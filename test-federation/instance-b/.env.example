# Instance B — federation test
# Copy this file: cp .env.example .env
# Then fill in the values below.

# ── Required ────────────────────────────────────────────────────────────────

SECRET_KEY=replace-with-a-different-long-random-string-instance-b
POSTGRES_PASSWORD=replace-with-a-different-strong-password-b

# ── Database (defaults match docker-compose.yml — change only if needed) ───

POSTGRES_DB=facechan_b
POSTGRES_USER=facechan_b

# ── Hosts ───────────────────────────────────────────────────────────────────

# Set this AFTER first boot once you have your .onion address.
# Get it with:
#   docker compose -f test-federation/instance-b/docker-compose.yml -p fc-b logs tor
#
# Format: http://<your-onion-address>.onion
FEDERATION_BASE_URL=

# ALLOWED_HOSTS must include your onion address (without http://)
# e.g. ALLOWED_HOSTS=abc456.onion
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Optional ────────────────────────────────────────────────────────────────

# CORS_ALLOWED_ORIGINS=http://localhost:8102
