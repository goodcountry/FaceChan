# Copy to .env and fill in values — NEVER commit .env to git.
# Default storage is local disk (media/ directory). No cloud storage required.

# ── Django core ────────────────────────────────────────────────────────────────
# SECRET_KEY: avoid $ signs — Docker Compose treats them as variable references.
# Use letters, numbers and punctuation like !@#%^&*()-_=+[] instead.
# Generate one here: https://djecrety.ir
SECRET_KEY=your-very-long-random-secret-key-here-no-dollar-signs
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
# Nginx preserves the original Host header (required for federation/ActivityPub),
# so Django sees the real hostname on every request — including onion addresses.
# Add your onion address (or clearnet domain) here or requests will get a 400 Bad Request.
# Tor example: ALLOWED_HOSTS=localhost,127.0.0.1,youraddress.onion

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Full connection URL. Docker Compose prod sets this automatically from the
# POSTGRES_* vars below — only set DATABASE_URL directly for Railway/external DBs.
DATABASE_URL=postgres://facechan:yourpassword@localhost:5432/facechan

# These are used by docker-compose.prod.yml to initialise the Postgres container.
POSTGRES_DB=facechan
POSTGRES_USER=facechan
POSTGRES_PASSWORD=yourpassword

# ── Federation ─────────────────────────────────────────────────────────────────
# Your instance's public base URL — used for ActivityPub federation.
# Onion instance: set to http://youronionaddress.onion (get this from first boot logs)
#   sudo docker-compose -f docker-compose.prod.yml -p <name> logs tor | grep "onion"
# Clearnet instance: set to https://yourdomain.com
# Leave blank to run without federation — the instance works fine, federation is just inactive.
FEDERATION_BASE_URL=

# ── CORS / CSRF ────────────────────────────────────────────────────────────────
# Add your public domain here for both settings when deploying to clearnet.
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=http://localhost

# ── Web workers ────────────────────────────────────────────────────────────────
# Number of Gunicorn workers. Default is 2. Rule of thumb: 2× CPU cores.
WEB_CONCURRENCY=2

# ── Media / file storage ───────────────────────────────────────────────────────
# Default: local disk storage under ./media/ — works out of the box.
# For Railway clearnet instance, swap to Cloudflare R2 (uncomment below).
#
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=facechan-media
# R2_PUBLIC_URL=https://media.yourdomain.com

# ── mCaptcha (optional) ────────────────────────────────────────────────────────
# Self-hosted proof-of-work captcha — Tor-compatible, no third parties.
# Set both to enable. Leave empty to disable (honeypot still active).
# https://mcaptcha.org/docs/getting-started/
#
# MCAPTCHA_URL=https://captcha.yourdomain.tld
# MCAPTCHA_SITE_KEY=your_site_key_here
